[global]
    monitor = 0
    enable_posix_regex = true
    script = ~/.config/quickshell/scripts/notify-hook.sh
    width = 350
    height = 200
    origin = top-right
    offset = 20x20
    notification_limit = 5
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 2
    progress_bar_corners = all
    icon_corner_radius = 8
    icon_corners = all
    gap_size = 4
    separator_color = frame
    sort = update
    idle_threshold = 120
    font = 'JetBrainsMono Nerd Font',monospace,sans-serif 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = end
    ignore_newline = no
    icon_theme = Adwaita
    icon_position = left
    min_icon_size = 32
    max_icon_size = 128
    icon_path = /usr/share/icons/gnome/16x16/status/:/usr/share/icons/gnome/16x16/devices/
    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/xdg-open
    title = Dunst
    class = Dunst
    corner_radius = 8
    corners = all
    force_xwayland = false
    mouse_left_click = do_action, close_current
    mouse_middle_click = none
    mouse_right_click = close_all
    frame_width = 1
    frame_color = "#33353A"

[urgency_low]
    background = "#1A1B20"
    foreground = "#8E8E93"
    timeout = 3

[urgency_normal]
    background = "#1A1B20"
    foreground = "#E3E3E8"
    timeout = 5
    override_pause_level = 30

[urgency_critical]
    background = "#F28B82"
    foreground = "#1A1B20"
    frame_color = "#F28B82"
    timeout = 0
    override_pause_level = 60
