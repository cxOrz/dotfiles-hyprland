#!/usr/bin/env bash
# Notification count for Waybar — outputs JSON with text and class
count=$(dunstctl count history 2>/dev/null || echo "0")
# Sanitize to integer
count=$(echo "$count" | tr -dc '0-9')
count=${count:-0}

if [ "$count" -gt 0 ]; then
    echo "{\"text\": \"${count}\", \"class\": \"has-notifs\", \"alt\": \"has-notifs\"}"
else
    echo "{\"text\": \"󰂚\", \"class\": \"empty\", \"alt\": \"empty\"}"
fi
